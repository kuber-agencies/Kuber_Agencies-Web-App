# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment secrets (NEVER commit the real .env) ─────────────────────────
.env
.env.local
.env.*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/

