# ─────────────────────────────────────────────────────────
# .env.example  —  copy this to .env for local development
#
# On Render: set these in Dashboard → Environment Variables
# NEVER commit the real .env file (it is in .gitignore)
# ─────────────────────────────────────────────────────────

# MongoDB connection string from MongoDB Atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.mongodb.net/kuber_agencies

# Node environment
NODE_ENV=development

# Port — leave this out on Render (Render sets it automatically)
# PORT=10000
